# ═══════════════════════════════════════════════════════
#  Auto Hub — переменные окружения
#  Скопировать в .env и заполнить значения
# ═══════════════════════════════════════════════════════

# ─── Общее ──────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Backend ────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1            # >1 только в production

# ─── PostgreSQL ─────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=autohub_db
POSTGRES_USER=autohub
POSTGRES_PASSWORD=change-me-postgres-password
# Async DSN (используется SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://autohub:change-me-postgres-password@localhost:5432/autohub_db

# ─── Redis ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# Cache TTL (секунды)
REDIS_CACHE_TTL=300
REDIS_SESSION_TTL=2592000    # 30 дней

# ─── Celery ─────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Elasticsearch ──────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=change-me-elastic-password
# Имена индексов
ES_INDEX_PARTNERS=partners
ES_INDEX_SERVICES=services
ES_INDEX_PRODUCTS=products

# ─── S3 / MinIO ─────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000   # MinIO (dev) / https://storage.yandexcloud.net (prod)
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-minio-secret
S3_REGION=ru-central1
S3_BUCKET_MEDIA=autohub-media
S3_BUCKET_DOCS=autohub-docs
S3_PUBLIC_URL=http://localhost:9000/autohub-media

# ─── JWT ────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# ─── Платежи — ЮKassa ───────────────────────────────────
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_RETURN_URL=https://autohub.ru/payment/return
YOOKASSA_WEBHOOK_SECRET=change-me-webhook-secret

# ─── SMS — SMS Центр (smsc.ru) ──────────────────────────
SMSC_LOGIN=your-smsc-login
SMSC_PASSWORD=your-smsc-password
SMSC_SENDER=AutoHub

# ─── Email — Unisender / SMTP ───────────────────────────
EMAIL_FROM=noreply@autohub.ru
EMAIL_FROM_NAME=Auto Hub
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=noreply@autohub.ru
SMTP_PASSWORD=change-me-smtp-password
SMTP_TLS=true
UNISENDER_API_KEY=your-unisender-api-key

# ─── Push-уведомления — Firebase FCM ────────────────────
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CREDENTIALS_PATH=/secrets/firebase-credentials.json

# ─── Telegram Bot ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ─── Яндекс Карты ───────────────────────────────────────
YANDEX_MAPS_API_KEY=your-yandex-maps-api-key
YANDEX_GEOCODER_API_KEY=your-yandex-geocoder-api-key

# ─── DaData ─────────────────────────────────────────────
DADATA_API_KEY=your-dadata-api-key
DADATA_SECRET_KEY=your-dadata-secret-key

# ─── Яндекс Vision (OCR) ────────────────────────────────
YANDEX_VISION_FOLDER_ID=your-folder-id
YANDEX_VISION_API_KEY=your-vision-api-key

# ─── GigaChat / YandexGPT ───────────────────────────────
GIGACHAT_CLIENT_ID=your-gigachat-client-id
GIGACHAT_CLIENT_SECRET=your-gigachat-secret
YANDEXGPT_FOLDER_ID=your-folder-id
YANDEXGPT_API_KEY=your-yandexgpt-api-key

# ─── OAuth ──────────────────────────────────────────────
# Госуслуги (ЕСИА)
ESIA_CLIENT_ID=your-esia-client-id
ESIA_CALLBACK_URL=https://autohub.ru/auth/esia/callback

# VK ID
VK_APP_ID=your-vk-app-id
VK_APP_SECRET=your-vk-secret
VK_CALLBACK_URL=https://autohub.ru/auth/vk/callback

# Яндекс ID
YANDEX_OAUTH_CLIENT_ID=your-yandex-oauth-client-id
YANDEX_OAUTH_SECRET=your-yandex-oauth-secret
YANDEX_OAUTH_CALLBACK_URL=https://autohub.ru/auth/yandex/callback

# ─── Мониторинг ─────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# ─── Корбина (RabbitMQ) для Emergency Broadcast ─────────
RABBITMQ_URL=amqp://autohub:change-me@localhost:5672/autohub
RABBITMQ_USER=autohub
RABBITMQ_PASSWORD=change-me-rabbitmq-password
